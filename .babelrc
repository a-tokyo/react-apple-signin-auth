{
  "presets": [
    "@babel/flow",
    [
      "@babel/env",
      {
        "targets": {
          "browsers": [
            "last 3 versions"
          ]
        }
      }
    ],
    "@babel/react"
  ],
  "plugins": [],
  "env": {
    "production": {
      "comments": false,
      "compact": "auto",
      "minified": true,
      "ignore": [
        "**/__tests__/",
        "**/__mocks__/",
        "**/*.test.js"
      ]
    },
    "esm": {
      "presets": [
        "@babel/flow",
        [
          "@babel/env",
          {
            "targets": {
              "browsers": [
                "last 3 versions"
              ]
            },
            "modules": false
          }
        ],
        "@babel/react"
      ],
      "comments": false,
      "compact": "auto",
      "minified": true,
      "ignore": [
        "**/__tests__/",
        "**/__mocks__/",
        "**/*.test.js"
      ]
    }
  }
}
